#!/bin/zsh
set -euo pipefail

: "${HERDR_BIN_PATH:?}"
: "${HERDR_ACTIVE_WORKSPACE_ID:?}"

tabs_json=$(
  "$HERDR_BIN_PATH" tab list --workspace "$HERDR_ACTIVE_WORKSPACE_ID"
)

picker_input=$(
  printf '%s\n' "$tabs_json" |
    jq -r '.result.tabs | sort_by(.number)[] | [.number, .label, .agent_status, .tab_id] | @tsv'
)

picker_status=0
selection=$(
  printf '%s\n' "$picker_input" |
    fzf \
      --delimiter=$'\t' \
      --with-nth=1,2,3 \
      --layout=reverse \
      --border \
      --prompt='tabs> ' \
      --header='number  tab  status'
) || picker_status=$?

if (( picker_status == 130 )); then
  exit 0
fi

(( picker_status == 0 )) || exit "$picker_status"
[[ -n "$selection" ]] || exit 0

tab_id=$(printf '%s\n' "$selection" | cut -f4)
"$HERDR_BIN_PATH" tab focus "$tab_id" >/dev/null
