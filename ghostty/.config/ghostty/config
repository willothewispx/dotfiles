font-family = Monaspace Neon NF
font-size = 16
font-feature = "'calt', 'liga', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10'"
font-thicken

theme = Catppuccin Mocha

background-opacity = 0.95
background-blur-radius = 10

window-padding-x = 15
window-padding-y = 10

scrollback-limit = 104857600

keybind = cmd+p=previous_tab
keybind = cmd+n=next_tab
keybind = cmd+c=text:\x03
keybind = cmd+shift+c=copy_to_clipboard:mixed
keybind = ctrl+f=write_scrollback_file:open
